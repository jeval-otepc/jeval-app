# Frontend Application Environment Variables

# Strapi Backend Configuration (Development)
NEXT_PUBLIC_STRAPI_URL=http://jeval-strapi-app:1337
STRAPI_API_TOKEN=your-strapi-api-token-here

# Backend Services Configuration (Development)
NEXT_PUBLIC_BACKEND_SERVICES_URL=http://jeval-strapi-app:1337
NEXT_PUBLIC_BACKEND_SERVICES_API_URL=http://jeval-strapi-app:1337/api
BACKEND_SERVICES_API_TOKEN=your-backend-services-token-here

# Environment-specific Backend Services
NEXT_PUBLIC_BACKEND_SERVICES_DEV_URL=http://jeval-strapi-app:1337
NEXT_PUBLIC_BACKEND_SERVICES_STAGING_URL=https://staging.jeval.otepc.go.th/admin
NEXT_PUBLIC_BACKEND_SERVICES_PROD_URL=https://jeval.otepc.go.th/admin

# Database Services Configuration
NEXT_PUBLIC_DB_SERVICES_URL=http://localhost:5432

# Authentication Settings
NEXT_PUBLIC_AUTH_PROVIDER=strapi
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret-here

# Application Settings
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=jeval-app
NEXT_PUBLIC_APP_VERSION=1.0.0

# Logging and Debugging
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_LOG_LEVEL=debug

# Network and Timeout Settings
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_CONNECTION_TIMEOUT=5000