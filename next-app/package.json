{
    "name": "jeval-app",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build --turbopack",
        "build:analyze": "cross-env ANALYZE=true npm run build",
        "start": "next start",
        "start:prod": "NODE_ENV=production npm run start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:auth": "node scripts/run-auth-tests.js --quick",
        "test:auth:full": "node scripts/run-auth-tests.js --jest",
        "test:auth:e2e": "node scripts/run-auth-tests.js --playwright",
        "test:production": "node scripts/run-auth-tests.js --all",
        "prepare": "husky install | true"
    },
    "dependencies": {
        "@auth/core": "^0.34.2",
        "@hookform/resolvers": "^5.2.1",
        "@tanstack/react-query": "^5.87.1",
        "jose": "^6.1.0",
        "jspdf": "^3.0.2",
        "lucide-react": "^0.542.0",
        "next": "15.5.2",
        "next-auth": "^4.24.11",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-hook-form": "^7.62.0",
        "react-to-print": "^3.1.1",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@next/bundle-analyzer": "^15.5.2",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "cross-env": "^10.0.0",
        "eslint": "^9",
        "eslint-config-next": "15.5.2",
        "husky": "^9.1.7",
        "jest": "^30.1.3",
        "lint-staged": "^16.1.6",
        "tailwindcss": "^4",
        "typescript": "5.9.2"
    }
}
